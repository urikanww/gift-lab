# Laravel API base (Sanctum SPA cookie auth - must share top-level domain in prod)
VITE_API_URL=http://localhost:8000

# Laravel Reverb (websockets). These mirror the backend REVERB_* / VITE_REVERB_* values.
VITE_REVERB_APP_KEY=local-reverb-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
