APP_NAME="Gift Lab"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ---
# Dev default is SQLite; production uses MySQL (see SETUP.md).
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=giftlab
# DB_USERNAME=giftlab
# DB_PASSWORD=

# --- Sessions / Sanctum SPA cookie auth ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
# SESSION_DOMAIN=.giftlab.example   # prod: shared parent of api. and app.
SANCTUM_STATEFUL_DOMAINS=localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Queue / cache ---
QUEUE_CONNECTION=sync
CACHE_STORE=database

# --- Broadcasting (Laravel Reverb) ---
# Dev: 'log' (no server needed). Prod: 'reverb' + a running reverb:start worker.
BROADCAST_CONNECTION=log
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# --- Filesystem (artwork / proofs / model files) ---
# Dev: 'local'. Prod: 's3' (DigitalOcean Spaces / any S3-compatible).
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sgp1
AWS_BUCKET=giftlab
AWS_ENDPOINT=https://sgp1.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Mail ---
MAIL_MAILER=log
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@giftlab.example"
MAIL_FROM_NAME="${APP_NAME}"

# --- 3D model source APIs (Phase 2). Empty => stub/fixture client. ---
THINGIVERSE_TOKEN=
CULTS3D_TOKEN=

# --- Stripe (B2C pay-now). Empty => fixture gateway (auto-succeeds in dev). ---
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
