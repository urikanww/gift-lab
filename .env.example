APP_NAME="Gift Lab"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ---
# Dev default is SQLite; production uses MySQL (see SETUP.md).
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=giftlab
# DB_USERNAME=giftlab
# DB_PASSWORD=

# --- Sessions / Sanctum SPA cookie auth ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
# Local dev over http keeps this false. PROD MUST set SESSION_SECURE_COOKIE=true
# (cookie only sent over HTTPS). If unset, config/session.php now defaults it to
# true for any non-local APP_ENV, so a forgotten prod value fails safe.
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
# SESSION_DOMAIN=.giftlab.example   # prod: shared parent of api. and app. (required for cross-subdomain lax cookie auth)
SANCTUM_STATEFUL_DOMAINS=localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Queue / cache ---
QUEUE_CONNECTION=sync
CACHE_STORE=database

# --- Broadcasting (Laravel Reverb) ---
# Dev: 'log' (no server needed). Prod: 'reverb' + a running reverb:start worker.
BROADCAST_CONNECTION=log
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# --- Filesystem (artwork / proofs / model files) ---
# Dev: 'local'. Prod: 's3' (DigitalOcean Spaces / any S3-compatible).
FILESYSTEM_DISK=local
# Disk for anonymous, account-free designer artwork (POST /uploads/artwork).
# MUST be private - anon uploads are served only via short-lived signed URLs.
# Dev: 'local' (storage/app/private). Prod: 'spaces_private'.
ARTWORK_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sgp1
AWS_BUCKET=giftlab
AWS_ENDPOINT=https://sgp1.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false
# Root folder every s3-disk read/write is scoped under (DO Spaces).
DO_STORAGE_FOLDER=GIFT_LAB

# --- MODEL_3D asset disks (see config/model3d.php) ---
# Which disk backs 3D model files, print-floor production files, and thumbnails.
# Dev: local/local/public (default). Prod: spaces_models/spaces_models/s3.
# spaces_models is a PRIVATE DO Spaces disk rooted at GIFT_LAB (model refs carry
# their own models3d/ prefix, so files land under GIFT_LAB/models3d/). NOT
# spaces_private (that is anon-artwork only, rooted at GIFT_LAB/anon-uploads).
MODEL3D_DISK=local
MODEL3D_PRODUCTION_DISK=local
MODEL3D_THUMBNAIL_DISK=public

# --- Mail ---
MAIL_MAILER=log
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@giftlab.example"
MAIL_FROM_NAME="${APP_NAME}"

# --- 3D model source APIs. Empty => stub/fixture client. ---
# Thingiverse app token: thingiverse.com/developers (create app, copy App Token).
THINGIVERSE_TOKEN=
# Cults3D: account nick + API key from cults3d.com account settings > API.
CULTS3D_USERNAME=
CULTS3D_TOKEN=

# --- Marketplace UV-blank feeds. Empty => fixture client. ---
# Shopee Affiliate Open Platform (SG): affiliate.shopee.sg > Open API.
SHOPEE_AFFILIATE_APP_ID=
SHOPEE_AFFILIATE_SECRET=
# SHOPEE_AFFILIATE_BASE_URL=https://open-api.affiliate.shopee.sg/graphql

# Lazada Open Platform affiliate app: open.lazada.com.
# Confirm the search/detail API paths in YOUR program's API console - Lazada
# scopes endpoints per affiliate program; defaults below may need adjusting.
LAZADA_AFFILIATE_APP_KEY=
LAZADA_AFFILIATE_SECRET=
# LAZADA_AFFILIATE_BASE_URL=https://api.lazada.sg/rest
# LAZADA_AFFILIATE_SEARCH_PATH=/marketing/product/search
# LAZADA_AFFILIATE_ITEM_PATH=/marketing/product/detail

# --- Headless slicer (PrusaSlicer CLI). Empty => manual estimate verification. ---
# Full path to the console binary, e.g.
#   Windows: C:\Program Files\Prusa3D\PrusaSlicer\prusa-slicer-console.exe
#   Linux:   /usr/bin/prusa-slicer
# When set: ingested models are sliced for real grams/print-minutes and
# auto-verified => zero-touch publish.
# Windows paths: use single quotes ('C:\Program Files\...') - double quotes
# make dotenv treat backslashes as escape sequences and the file fails to parse.
SLICER_BINARY=
# SLICER_TIMEOUT=300
# Filament density for gram computation when the slicer profile has none (PLA 1.24)
# SLICER_FILAMENT_DENSITY=1.24
# OrcaSlicer CLI + Bambu H2S (O1S) profile bundle. When set, ingested STLs are
# sliced to an H2S-ready .gcode.3mf persisted as production_file_ref, and grams/
# minutes are read from the same pass. Empty => falls back to SLICER_BINARY behavior.
ORCA_SLICER_BINARY=
ORCA_H2S_PROFILE=

# --- LLM layer of the IP/trademark screen. Provider-selectable; the keyword
# blocklist always runs. Missing credentials => blocklist-only.
# Providers: anthropic (console.anthropic.com) | openai (platform.openai.com)
#            | ollama (self-hosted, free - set OLLAMA_BASE_URL, e.g. http://localhost:11434)
IP_SCREEN_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_BASE_URL=
# OLLAMA_MODEL=llama3.2

# --- Stripe (B2C pay-now). Empty => fixture gateway (auto-succeeds in dev). ---
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# --- NinjaVan courier (delivery dispatch). Empty => fixture client (dev/testing;
# never dispatches a real parcel). Client id/secret: NinjaVan Dashboard > Developer.
# Set NINJAVAN_BASE_URL to the production host (https://api.ninjavan.co/SG) when
# going live - note the UPPERCASE country segment. Fill the pickup fields with the
# real warehouse (name/phone/email/address1/postcode/country).
NINJAVAN_CLIENT_ID=
NINJAVAN_CLIENT_SECRET=
# NINJAVAN_BASE_URL=https://api-sandbox.ninjavan.co/SG
# NINJAVAN_SERVICE_TYPE=Parcel
# NINJAVAN_SERVICE_LEVEL=Standard
# NINJAVAN_DEFAULT_WEIGHT_KG=1
# NINJAVAN_TIMEZONE=Asia/Singapore
# NINJAVAN_TIMESLOT_START=09:00
# NINJAVAN_TIMESLOT_END=18:00
NINJAVAN_PICKUP_NAME="Gift Lab"
NINJAVAN_PICKUP_PHONE=
NINJAVAN_PICKUP_EMAIL=
NINJAVAN_PICKUP_ADDRESS1=
NINJAVAN_PICKUP_CITY=
NINJAVAN_PICKUP_STATE=
NINJAVAN_PICKUP_POSTCODE=
NINJAVAN_PICKUP_COUNTRY=SG
