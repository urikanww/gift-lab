# Gift Lab - backend production env template (copy to .env, fill secrets, then
# `php artisan key:generate`). See DEPLOYMENT.md.

APP_NAME="Gift Lab"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.giftlab.example
APP_TIMEZONE=UTC

# --- Database (MySQL) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=giftlab
DB_USERNAME=giftlab
DB_PASSWORD=

# --- Sessions / Sanctum SPA cookie auth ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
# Shared parent domain so the cookie is valid for both api. and app.
SESSION_DOMAIN=.giftlab.example
# SPA origins allowed to authenticate statefully.
SANCTUM_STATEFUL_DOMAINS=app.giftlab.example

# --- CORS (config/cors.php reads these patterns; supports_credentials=true) ---
CORS_ALLOWED_ORIGINS=https://app.giftlab.example

# --- Queue + cache (Redis recommended) ---
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Broadcasting: Laravel Reverb (websockets) ---
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb.giftlab.example
REVERB_PORT=443
REVERB_SCHEME=https
# The local bind for the reverb:start process (behind Nginx).
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080

# --- Object storage for artwork / proof / model files (DO Spaces, S3-compat) ---
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sgp1
AWS_BUCKET=giftlab
AWS_ENDPOINT=https://sgp1.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Mail (quote/proof notifications) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@giftlab.example"
MAIL_FROM_NAME="${APP_NAME}"

LOG_CHANNEL=stack
LOG_LEVEL=warning
